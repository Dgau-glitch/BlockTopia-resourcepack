{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "angel_totem",
        "model": {
          "type": "minecraft:composite",
          "models": [
            {
              "type": "minecraft:model",
              "model": "block_topia:item/angel_totem"
            }
          ]
        }
      },
      {
        "when": "demon_totem",
        "model": {
          "type": "minecraft:composite",
          "models": [
            {
              "type": "minecraft:model",
              "model": "block_topia:item/demon_totem"
            }
          ]
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/totem_of_undying"
    }
  }
}